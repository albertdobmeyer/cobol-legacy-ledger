{
  "name": "COBOL Legacy Ledger",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y gnucobol && pip install -e '.[dev]' && ./scripts/build.sh && ./scripts/seed.sh",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "COBOL Legacy Ledger API",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "uvicorn python.api.app:app --host 0.0.0.0 --port 8000 &",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "broadcommfd.cobol-language-support"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
